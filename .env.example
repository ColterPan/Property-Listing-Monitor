# Copy this file to .env and fill in your own values. Never commit the real .env.

# Create a bot via @BotFather on Telegram, then paste the token it gives you here.
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceThisWithYourOwn

# Message your new bot once, then fetch your chat ID via @userinfobot or
# https://api.telegram.org/bot<your-token>/getUpdates (see README for details).
TELEGRAM_CHAT_ID=123456789
